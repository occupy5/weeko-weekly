# Template for Hardhat environment variables.

# To use this template, copy this file, rename it .env, and fill in the values.

# To access the values stored in this .env file you can use: process.env.VARIABLENAME
# Optional unless you use an Alchemy-backed network or contract verification.
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=

# Don't fill this value manually, run yarn generate to generate a new account or yarn account:import to import an existing PK.
DEPLOYER_PRIVATE_KEY_ENCRYPTED=

# Base Sepolia publication settings. CONTENT_URI should resolve to the uploaded publication.json.
RPC_URL=https://sepolia.base.org
CONTENT_URI=
RUN_LOG_URI=

# Optional metadata used by `yarn publication:manifest`.
PUBLICATION_TITLE=
PUBLICATION_SUMMARY=
CREATOR_ADDRESS=
AGENT_DURATION_SECONDS=
AGENT_ITERATIONS=
AGENT_TOOL_CALLS=
