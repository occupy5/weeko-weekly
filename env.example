# Weeko environment template
#
# Copy this file to `.env` for the root content-production workflow:
#
#   cp env.example .env
#
# The dApp packages read their own env files. For Web3 work, also copy:
#
#   cp dapp/packages/hardhat/.env.example dapp/packages/hardhat/.env
#   cp dapp/packages/nextjs/.env.example dapp/packages/nextjs/.env.local
#
# Keep real API keys and private keys out of git.

# -----------------------------------------------------------------------------
# Root workflow: narration audio
# -----------------------------------------------------------------------------

# Required only when running `python3 tools/tts.py` without `--dry-run`, or when
# listing ElevenLabs voices.
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# dApp frontend: dapp/packages/nextjs/.env.local
# -----------------------------------------------------------------------------

# Optional. Base Sepolia uses the public RPC override below by default.
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Optional for local demos. Use your own public WalletConnect project ID for a
# deployed app to avoid sharing quotas.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Public Base Sepolia RPC. Replace with your own RPC if needed.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional build flags.
NEXT_PUBLIC_IPFS_BUILD=false
NEXT_PUBLIC_IGNORE_BUILD_ERROR=false

# -----------------------------------------------------------------------------
# dApp contracts and publication scripts: dapp/packages/hardhat/.env
# -----------------------------------------------------------------------------

# Optional unless you use Alchemy-backed networks, forking, or contract
# verification.
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=

# Do not fill this manually. Generate or import it with:
#   cd dapp && corepack yarn account:generate
#   cd dapp && corepack yarn account:import
DEPLOYER_PRIVATE_KEY_ENCRYPTED=

# Optional raw publisher key for scripted publishing. Prefer the encrypted
# deployer account or interactive wallet flows. Never commit a real key.
PUBLISHER_PRIVATE_KEY=

# Publication network and RPC. Use `default` for the local Hardhat chain or
# `baseSepolia` for the Base Sepolia testnet.
DEPLOYMENT_NETWORK=default
RPC_URL=http://127.0.0.1:8545

# Required for testnet publication. CONTENT_URI should point to the uploaded
# publication.json, and RUN_LOG_URI should point to the uploaded run-log.json.
CONTENT_URI=
RUN_LOG_URI=

# Optional metadata used by `bun run dapp:manifest`.
PUBLICATION_TITLE=
PUBLICATION_SUMMARY=
CREATOR_ADDRESS=
AGENT_DURATION_SECONDS=
AGENT_ITERATIONS=
AGENT_TOOL_CALLS=

# Dry-run a publish script without sending a transaction.
PUBLISH_PREFLIGHT=false

# Enable only when intentionally forking mainnet with a configured RPC key.
MAINNET_FORKING_ENABLED=false
